---
tracker:
  kind: local
  issues_dir: ./issues
  active_states:
    - Todo
    - In Progress
  terminal_states:
    - Done
    - Cancelled

polling:
  interval_ms: 10000

workspace:
  root: ./workspaces

agent:
  kind: ollama
  model: qwen3:8b
  max_turns: 10

server:
  port: 4000
---
